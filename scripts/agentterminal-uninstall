#!/bin/bash

# agentterminal-uninstall: 清理 AgentTerminal 安装的所有残留文件
#
# 用法:
#   agentterminal-uninstall          # 交互式确认
#   agentterminal-uninstall --force  # 跳过确认

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

FORCE=false
if [[ "${1:-}" == "--force" ]]; then
    FORCE=true
fi

APP_SUPPORT="$HOME/Library/Application Support/agentterminal"
CACHES="$HOME/Library/Caches/agentterminal"
PREFERENCES="$HOME/Library/Preferences/com.agentterminal.app.plist"

echo -e "${YELLOW}AgentTerminal 卸载工具${NC}"
echo ""
echo "将清理以下文件："
echo "  - $APP_SUPPORT"
echo "  - $CACHES"
echo "  - $PREFERENCES"
echo ""

if [ "$FORCE" = false ]; then
    read -p "确认删除？(y/N) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo -e "${YELLOW}已取消${NC}"
        exit 0
    fi
fi

# 清理 Application Support
if [ -d "$APP_SUPPORT" ]; then
    rm -rf "$APP_SUPPORT"
    echo -e "${GREEN}✓${NC} 已删除 $APP_SUPPORT"
else
    echo -e "${YELLOW}·${NC} $APP_SUPPORT 不存在，跳过"
fi

# 清理 Caches
if [ -d "$CACHES" ]; then
    rm -rf "$CACHES"
    echo -e "${GREEN}✓${NC} 已删除 $CACHES"
else
    echo -e "${YELLOW}·${NC} $CACHES 不存在，跳过"
fi

# 清理 Preferences
if [ -f "$PREFERENCES" ]; then
    rm -f "$PREFERENCES"
    echo -e "${GREEN}✓${NC} 已删除 $PREFERENCES"
else
    echo -e "${YELLOW}·${NC} $PREFERENCES 不存在，跳过"
fi

echo ""
echo -e "${GREEN}卸载完成${NC}"
